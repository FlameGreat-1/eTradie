    {
      "mode": "managed",
      "type": "vault_policy",
      "name": "mt_node_provisioner",
      "provider": "provider[\"registry.terraform.io/hashicorp/vault\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "id": "mt-node-provisioner-staging",
            "name": "mt-node-provisioner-staging",
            "namespace": null,
            "policy": "# Engine writes per-tenant credentials. WRITE only - no read, no list.\npath \"etradie/data/tenants/mt-node/*\" {\n  capabilities = [\"create\", \"update\", \"delete\"]\n}\n\n# Engine performs hard-delete of all versions on connection-delete to\n# purge the credentials from Vault entirely. Requires 'delete' on the\n# metadata endpoint (Vault treats this differently from data delete).\npath \"etradie/metadata/tenants/mt-node/*\" {\n  capabilities = [\"delete\"]\n}\n"
          },
          "sensitive_attributes": [],
          "identity_schema_version": 0,
          "private": "bnVsbA=="
        }
      ]
    },
    {
      "mode": "managed",
