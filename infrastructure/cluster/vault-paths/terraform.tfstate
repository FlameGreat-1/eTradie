      "provider": "provider[\"registry.terraform.io/hashicorp/vault\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "id": "mt-node-tenant-staging",
            "name": "mt-node-tenant-staging",
            "namespace": null,
            "policy": "path \"etradie/data/tenants/mt-node/{{identity.entity.aliases.auth_kubernetes_1f865701.metadata.service_account_name}}\" {\n  capabilities = [\"read\"]\n}\n"
          },
          "sensitive_attributes": [],
          "identity_schema_version": 0,
          "private": "bnVsbA==",
          "dependencies": [
            "vault_auth_backend.kubernetes"
          ]
        }
