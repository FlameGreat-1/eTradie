# ── Trivy Misconfiguration Suppressions ──────────────────────
# These are intentional, documented exceptions — not security gaps.

# KSV-0014: readOnlyRootFilesystem=false on Postgres
# Postgres requires a writable /var/run/postgresql for its UNIX
# domain socket. The official postgres:16-alpine image does not
# support readOnlyRootFilesystem=true. The data directory lives
# on a PVC, all capabilities are dropped, and the container runs
# as non-root (uid 70). This is the accepted industry-standard
# posture for containerised Postgres.
KSV-0014

# KSV-0109: ConfigMap "stores secrets" false positive
# Trivy flags any ConfigMap key containing the substring "TOKEN"
# or "SECRET" as a leaked credential. Our ConfigMap keys are:
#   AUTH_ACCESS_TOKEN_TTL_SECONDS   (integer: 900)
#   AUTH_REFRESH_TOKEN_TTL_SECONDS  (integer: 604800)
#   AUTH_SERVICE_TOKEN_TTL_SECONDS  (integer: 86400)
#   AUTH_RETURN_TOKENS_IN_BODY      (boolean: "false")
# These are non-secret TTL durations and feature flags. The actual
# signing keys and passwords are stored in ExternalSecrets backed
# by HashiCorp Vault, never in ConfigMaps.
KSV-0109
