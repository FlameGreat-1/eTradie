# ═══════════════════════════════════════════════════════════════
# Broker-Specific Configuration
# ═══════════════════════════════════════════════════════════════

MT5_CONNECTION_TIMEOUT_SECONDS=30
MT5_MAX_CANDLES_PER_REQUEST=5000

TRADINGVIEW_MAX_PAYLOAD_SIZE_BYTES=10240
TRADINGVIEW_SIGNATURE_HEADER=X-TradingView-Signature
TRADINGVIEW_TIMEOUT_SECONDS=10
TRADINGVIEW_ALLOWED_IPS=
TRADINGVIEW_VALIDATE_SIGNATURE=true

# Twelve Data is the fallback market data provider when the primary
# broker (EA or MetaAPI) is unavailable. Always configured via env var.
TWELVE_DATA_TIMEOUT_SECONDS=30
TWELVE_DATA_MAX_RETRIES=3
TWELVE_DATA_RETRY_DELAY_SECONDS=2
TWELVE_DATA_RATE_LIMIT_PER_MINUTE=8
TWELVE_DATA_MAX_CANDLES_PER_REQUEST=5000
TWELVE_DATA_CACHE_TTL_SECONDS=300

# ═══════════════════════════════════════════════════════════════
# Credential Encryption
# ═══════════════════════════════════════════════════════════════
# Used to encrypt API keys and auth tokens stored in the database
# (broker connections and LLM connections). Uses Fernet symmetric
# encryption with a key derived from this value via SHA-256.
#
# IMPORTANT: If you change this after saving connections, all
# existing encrypted credentials become unreadable. You would
# need to re-enter them via the dashboard.
#
# If not set, falls back to DATABASE_URL for key derivation.
# In production, set a dedicated random string (min 32 chars).

# BROKER_ENCRYPTION_KEY=your-random-secret-string-min-32-chars
# LLM_ENCRYPTION_KEY=your-random-secret-string-min-32-chars

# ═══════════════════════════════════════════════════════════════
# Authentication (OAuth 2.0)
# ═══════════════════════════════════════════════════════════════
#
# JWT signing secret. Must be at least 32 characters.
# In development, if left empty a random secret is generated (tokens
# won't survive restarts). In production, set a strong random string.
#
# Generate one with: openssl rand -hex 64
AUTH_JWT_SECRET=CHANGE_ME_IN_PRODUCTION_MIN_32_CHARS

# Access token lifetime in seconds. Default: 900 (15 minutes).
AUTH_ACCESS_TOKEN_TTL_SECONDS=900

# Refresh token lifetime in seconds. Default: 604800 (7 days).
AUTH_REFRESH_TOKEN_TTL_SECONDS=604800

# Bcrypt cost factor for password hashing. Range: 10-14. Default: 12.
AUTH_BCRYPT_COST=12

# Initial admin user credentials. Created on first startup if no
# admin exists in the database. Change the password after first login.
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD=CHANGE_ME_IN_PRODUCTION
AUTH_ADMIN_EMAIL=admin@etradie.local

# Maximum active refresh sessions per user. When exceeded, the oldest
# session is automatically revoked. Default: 5.
AUTH_MAX_SESSIONS_PER_USER=5

# JWT issuer claim. Default: etradie.
AUTH_ISSUER=etradie

# ── Forgot / Reset password ─────────────────────────────────
#
# AUTH_PASSWORD_RESET_TOKEN_TTL_SECONDS
#   Lifetime of the single-use bearer token carried in the emailed
#   reset link. Default 3600 (1 hour). Bounded at startup to
#   300..86400 (5 minutes .. 24 hours) so an operator cannot ship a
#   permanent reset link by accident. The SPA reads the live value
#   from GET /auth/password/policy and renders the real expiry in
#   the 'check your inbox' card; do not assume 60 minutes elsewhere.
AUTH_PASSWORD_RESET_TOKEN_TTL_SECONDS=3600

# AUTH_FRONTEND_BASE_URL
#   Origin used to construct the user-facing reset link inserted
#   into the email body: <base>/reset-password?token=<hex>.
#
#   REQUIRED in production. Validated at startup as an absolute
#   http(s) URL with no path / query / fragment; the gateway refuses
#   to start on any other shape. If unset, the gateway falls back to
#   the request's Origin header but only when the origin is https,
#   or the host is localhost / 127.0.0.1 — the http+remote-host
#   combination is refused so an unverified Origin cannot redirect
#   the reset link to an attacker-controlled domain.
#
#   Conventions:
#     Dev (Vite on :5173):      http://localhost:5173
#     Production single-host:   https://app.exoper.com
#     Production multi-region:  https://app.<region>.exoper.com
AUTH_FRONTEND_BASE_URL=

# Database URL for auth tables. If empty, constructed from POSTGRES_*
# variables above (recommended). Only set this if auth uses a separate DB.
# AUTH_DATABASE_URL=

# ── Google OAuth 2.0 (Authorization Code + PKCE, server-mediated) ──────────
#
# When AUTH_GOOGLE_OAUTH_ENABLED=true, the gateway exposes:
#   POST   /auth/oauth/google/start          → sign-in (public)
#   POST   /auth/oauth/google/callback       → sign-in (public)
#   POST   /auth/oauth/google/link/start     → link    (auth required)
#   POST   /auth/oauth/google/link/callback  → link    (auth required)
#   DELETE /auth/oauth/google/link           → unlink  (auth required)
#
# The browser never holds the Google client secret or a Google token.
# AUTH_GOOGLE_CLIENT_ID, AUTH_GOOGLE_CLIENT_SECRET,
# AUTH_GOOGLE_REDIRECT_URI, and AUTH_GOOGLE_LINK_REDIRECT_URI are
# MANDATORY when enabled; startup fails fast otherwise.
#
# Each redirect URI must EXACTLY match an entry in the "Authorized
# redirect URIs" list of this OAuth client in Google Cloud Console.
# The two URIs MUST differ — a single shared URI would conflate the
# sign-in and link flows on the IdP side and break the
# defence-in-depth boundary that the separate handlers rely on.
#
# Conventions:
#   AUTH_GOOGLE_REDIRECT_URI       → https://<frontend-host>/auth/callback/google
#   AUTH_GOOGLE_LINK_REDIRECT_URI  → https://<frontend-host>/settings/oauth/callback/google
AUTH_GOOGLE_OAUTH_ENABLED=false
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_GOOGLE_REDIRECT_URI=
AUTH_GOOGLE_LINK_REDIRECT_URI=

# Optional: comma-separated list of Google Workspace `hd` (hosted-domain)
# claims that are allowed to sign in. Leave empty to accept any Google
# account (consumer + workspace).
# AUTH_GOOGLE_ALLOWED_HOSTED_DOMAINS=exoper.com

# Lifetime of an in-flight authorize record (PKCE / state / nonce).
# Bounds: 60..1800 seconds. Default: 600 (10 minutes).
AUTH_OAUTH_FLOW_TTL_SECONDS=600

# Per-request HTTP timeout for outbound calls to Google's token and
# JWKS endpoints. Bounds: 1..30 seconds. Default: 10.
AUTH_OAUTH_HTTP_TIMEOUT_SECONDS=10

# ── Cookie auth (access_token + refresh_token + csrf_token) ───────────────
#
# The dashboard authenticates via HttpOnly cookies set by the gateway on
# /auth/login, /auth/register, /auth/refresh, and the OAuth callbacks.
# These knobs control the Domain / Secure / SameSite attributes on every
# auth cookie, and the request header the SPA echoes the CSRF token in.
#
# The defaults below are LOCAL-DEV defaults: Secure=false +
# SameSite=Lax let a plain-HTTP gateway issue and read cookies
# against a Vite dev server running on a different port. They are
# WRONG for production — production overlays MUST set them per the
# matrix below (see docs/cookie-auth.md for the full runbook).
#
#   Local-dev HTTP:
#     AUTH_COOKIE_SECURE=false
#     AUTH_COOKIE_SAMESITE=Lax
#     AUTH_COOKIE_DOMAIN=             # empty: host-only
#
#   Production single-host HTTPS (gateway + SPA on same host):
#     AUTH_COOKIE_SECURE=true
#     AUTH_COOKIE_SAMESITE=Strict
#     AUTH_COOKIE_DOMAIN=             # empty: host-only
#
#   Production cross-subdomain HTTPS (e.g. app.exoper.com + api.exoper.com):
#     AUTH_COOKIE_SECURE=true
#     AUTH_COOKIE_SAMESITE=None       # required for cross-site cookies
#     AUTH_COOKIE_DOMAIN=.exoper.com  # registrable domain, with leading dot
#
# Notes:
#   - Secure=false + SameSite=None is rejected by browsers AND by
#     Config.validate() (fail-fast at startup).
#   - AUTH_CSRF_HEADER must match the header name the frontend
#     attaches to every POST/PUT/PATCH/DELETE. The default
#     (X-CSRF-Token) matches cotradee/src/lib/axios.ts.
#   - GATEWAY_ALLOWED_ORIGINS must list the SPA origin EXACTLY
#     (scheme + host + port) for the browser to send credentialed
#     cross-origin requests at all; the gateway already includes
#     the common dev origins by default.
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=Lax
AUTH_CSRF_HEADER=X-CSRF-Token
AUTH_CSRF_SIGNED=true
AUTH_RETURN_TOKENS_IN_BODY=false
AUTH_ALLOW_SAMESITE_LAX_IN_PROD=false

# Engine internal shared secret.
# The gateway sends this in X-Internal-Auth on every /internal/* call to
# the engine. Must match ENGINE_INTERNAL_SHARED_SECRET on the engine side.
# Generate with: openssl rand -hex 32
# Required in production; in development the engine logs a warning and
# rejects all /internal/* requests with 401 until this is set.
GATEWAY_ENGINE_INTERNAL_SHARED_SECRET=CHANGE_ME_IN_PRODUCTION_MIN_32_CHARS
ENGINE_INTERNAL_SHARED_SECRET=CHANGE_ME_IN_PRODUCTION_MIN_32_CHARS

# ── Service-wide credentialed-CORS allow-list ───────────────────────────────
#
# Backend services that accept credentialed XHR from the SPA (the
# Python engine, the Go management HTTP API, and the Go execution
# HTTP API) all share the same allow-list. List EVERY origin the SPA
# might be served from, scheme + host + port. Empty / unset disables
# cross-origin requests entirely, which is the correct default for
# server-to-server deployments.
#
# IMPORTANT: this is INDEPENDENT of GATEWAY_ALLOWED_ORIGINS. The
# gateway maintains its own list because it serves /auth and is the
# only service that mints cookies. In any deployment where the SPA
# talks to all four services, the SPA origin must appear in BOTH
# variables.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# Service-specific overrides. Useful when the management / execution
# HTTP APIs are reachable from a different SPA origin than the engine
# (e.g. an admin dashboard on a separate subdomain). Leave empty to
# inherit ALLOWED_ORIGINS above.
MANAGEMENT_ALLOWED_ORIGINS=
EXECUTION_ALLOWED_ORIGINS=

# ── LLM Token Metering (Pro Managed quota enforcement) ──────────────────────
#
# AUTH_TIER_PRO_MANAGED_DAILY_INPUT_TOKENS
#   Maximum input tokens a Pro Managed user may consume per calendar day
#   (UTC). Default 2,000,000 (~$6 at Sonnet 4 pricing). Set to 0 to
#   disable the daily input cap (not recommended in production).
#
# AUTH_TIER_PRO_MANAGED_DAILY_OUTPUT_TOKENS
#   Maximum output tokens per day. Default 200,000 (~$3 at Sonnet 4).
#
# AUTH_TIER_PRO_MANAGED_MONTHLY_INPUT_TOKENS
#   Maximum input tokens per billing period. Default 20,000,000.
#
# AUTH_TIER_PRO_MANAGED_MONTHLY_OUTPUT_TOKENS
#   Maximum output tokens per billing period. Default 2,000,000.
#
# AUTH_TIER_PRO_MANAGED_MAX_INPUT_PER_CALL
#   Hard ceiling on the estimated input tokens for a single LLM call.
#   Prevents a runaway context-assembly bug from making one absurdly
#   expensive call. Default 300,000 (well above the largest legitimate
#   prompt; the engine's user_message is ~280 KB worst case).
#
# AUTH_TIER_PRO_MANAGED_SOFT_CAP_PERCENT
#   Percentage of the monthly cap at which the SPA shows an amber
#   'approaching limit' banner. Default 80. Informational only; the
#   hard cap is enforced at 100%.
#
# AUTH_TIER_PRO_MANAGED_ALLOWED_MODELS
#   Comma-separated list of model identifiers (case-insensitive) that
#   Pro Managed users may use. Empty = any model the provider supports.
#   Example: claude-sonnet-4-5,claude-3-5-sonnet-20241022
#
# AUTH_LLM_RESERVATION_TTL_SECONDS
#   How long a held reservation survives before the reconciler reaps it
#   as a Refund. Must be > the engine's total_timeout_seconds (default
#   90 s). Default 300 s (5 minutes). Range: 30..3600.
#
# Per-user rate limits on POST /api/v1/cycle/run (the dashboard
# 'Run Now' button). Keyed by JWT subject so two tabs on the same
# account share one bucket.
#
# AUTH_TIER_FREE_CYCLE_RPM / _BURST
# AUTH_TIER_PRO_BYOK_CYCLE_RPM / _BURST
# AUTH_TIER_PRO_MANAGED_CYCLE_RPM / _BURST
#   Requests per minute and burst capacity per tier. Defaults:
#     free:        2 / 3
#     pro_byok:    30 / 60   (user pays their own LLM bill)
#     pro_managed: 10 / 20   (platform pays; tighter)
AUTH_TIER_PRO_MANAGED_DAILY_INPUT_TOKENS=2000000
AUTH_TIER_PRO_MANAGED_DAILY_OUTPUT_TOKENS=200000
AUTH_TIER_PRO_MANAGED_MONTHLY_INPUT_TOKENS=20000000
AUTH_TIER_PRO_MANAGED_MONTHLY_OUTPUT_TOKENS=2000000
AUTH_TIER_PRO_MANAGED_MAX_INPUT_PER_CALL=300000
AUTH_TIER_PRO_MANAGED_SOFT_CAP_PERCENT=80
AUTH_TIER_PRO_MANAGED_ALLOWED_MODELS=
AUTH_LLM_RESERVATION_TTL_SECONDS=300
AUTH_TIER_FREE_CYCLE_RPM=2
AUTH_TIER_FREE_CYCLE_BURST=3
AUTH_TIER_PRO_BYOK_CYCLE_RPM=30
AUTH_TIER_PRO_BYOK_CYCLE_BURST=60
AUTH_TIER_PRO_MANAGED_CYCLE_RPM=10
AUTH_TIER_PRO_MANAGED_CYCLE_BURST=20

# ── Engine metering (set on the engine side, not the gateway) ────────────────
#
# METERING_ENABLED
#   Set to 'false' in local dev when no gateway is running. Default true.
#   In production/staging the engine fails fast if this is true and
#   METERING_GATEWAY_URL is not set.
#
# METERING_GATEWAY_URL
#   Base URL of the gateway HTTP server the engine calls for metering.
#   Must match the gateway's HTTP port. Example: http://gateway:8080
#   Required in production when METERING_ENABLED=true.
METERING_ENABLED=true
METERING_GATEWAY_URL=http://gateway:8080

# ── Auth Trust Chain (Cloudflare → edge-ingress → envoy → gateway) ─────────────
#
# AUTH_TRUSTED_PROXY_CIDRS: comma-separated CIDR list of peer addresses
# that the trust-aware client-IP resolver (src/auth/clientip.go) treats
# as legitimate forwarders. Forwarding headers (X-Forwarded-For,
# X-Real-IP, CF-Connecting-IP) from peers in these ranges are honoured;
# from any other peer they are ignored entirely.
#
# 172.28.0.0/16 is the actual subnet of the docker-compose
# `etradie-network` (see deployments/edge-ingress/docker/docker-
# compose.yml networks block). With this set, when edge-ingress
# forwards a request to gateway under `docker compose --profile edge
# up`, the gateway honours the forwarded client-IP headers and the
# trust-chain code path is exercised exactly like in staging /
# production.
#
# Cluster overrides: staging uses 10.42.0.0/16, production uses
# 10.100.0.0/16. The kustomize / helm overlays carry those values.
AUTH_TRUSTED_PROXY_CIDRS=172.28.0.0/16

# AUTH_TRUST_CLOUDFLARE: when true, the resolver additionally trusts
# Cloudflare's published IPv4 + IPv6 origin ranges (embedded in
# src/auth/clientip.go, refreshable via
# deployments/cloudflare/scripts/refresh-cloudflare-ips.sh). Local dev
# has no real Cloudflare zone in front of it, so this is correctly
# false in dev. Production overrides this to true via the kustomize
# / helm overlays.
AUTH_TRUST_CLOUDFLARE=false

# ── Edge Profile build args ──────────────────────────────────────────
# OCI image labels stamped into the edge-ingress build by the
# Dockerfile ARG block. Must be present so docker build never fails
# on an unset var; CI overrides them with real values.
BUILD_DATE=2024-01-01T00:00:00Z
GIT_COMMIT=unknown

# ── Edge Profile envoy WASM filter ─────────────────────────────────────
#
# Path to the built etradie_envoy_integration_filter.wasm. The
# docker-compose `edge` profile mounts this file into the envoy
# container at /etc/envoy/wasm/integration-filter.wasm, mirroring the
# helm chart's ConfigMap mount.
#
# Build the WASM before `make edge-up`:
#   make envoy-build
#
# Default points at the cargo target directory; override if you build
# elsewhere.
EDGE_ENVOY_WASM_PATH=./src/envoy/target/wasm32-wasi/release/etradie_envoy_integration_filter.wasm

# ── Cloudflare Authenticated Origin Pulls (AOP) ─────────────────────────────
#
# CLOUDFLARE_AOP_CA_PATH: in-container path at which the AOP CA bundle
# is mounted. Must match `tls.client_auth.ca_path` in the active
# edge-ingress.yaml. Same value across local / staging / production.
CLOUDFLARE_AOP_CA_PATH=/etc/edge-ingress/cloudflare/origin-pull-ca.pem

# ── MaxMind GeoIP (edge-ingress geo-routing) ──────────────────────────────────
#
# Required by the edge-geoip-init container that runs alongside
# edge-ingress under `make edge-up` (docker-compose `edge` profile).
# The container is the official maxmindinc/geoipupdate:v6.0 image
# and needs BOTH the account ID and the license key. Both values
# come from a single free GeoLite2 sign-up at:
#   https://www.maxmind.com/en/geolite2/signup
#
# Free GeoLite2 credentials are sufficient for development. In
# staging / production these come from Vault via the
# maxmind-credentials ExternalSecret
# (helm/edge-ingress/templates/externalsecret-maxmind.yaml).
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=

# ── Grafana ─────────────────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=CHANGE_ME_IN_PRODUCTION

# ── ChromaDB Server Auth ─────────────────────────────────────
# This token is used by docker-compose for the ChromaDB server.
# It must match RAG_CHROMA_AUTH_TOKEN above so the engine client
# can authenticate with the ChromaDB server.
CHROMA_AUTH_TOKEN=etradie_chroma_dev_token

# ═══════════════════════════════════════════════════════════════
# Advanced HTTP & Circuit Breaker Settings
# ═══════════════════════════════════════════════════════════════

CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60
CIRCUIT_BREAKER_HALF_OPEN_MAX_CALLS=3

# ═══════════════════════════════════════════════════════════════
# SMTP / Email (Waitlist & Transactional Emails)
# ═══════════════════════════════════════════════════════════════
#
# Configure SMTP credentials to enable email delivery for the
# waitlist feature. When unconfigured, waitlist entries are still
# recorded in PostgreSQL but welcome emails are skipped.
#
# Common providers:
#   Gmail:     smtp.gmail.com:587 (use App Password)
#   Hostinger: smtp.hostinger.com:587
#   SendGrid:  smtp.sendgrid.net:587
#   Mailgun:   smtp.mailgun.org:587
#
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Exoper

# ═════════════════════════════════════════════════════════════════
# Support & Contact Us (Ticketing + multi-channel notifications)
# ═════════════════════════════════════════════════════════════════
#
# The support module persists customer tickets in PostgreSQL and fans
# every new ticket / reply / close out to the channels configured
# below. Every value is optional: unset values disable the matching
# channel and the gateway continues serving tickets normally.
#
# Email fan-out reuses the SMTP credentials configured above; no
# additional SMTP setup is required here. Only the inbox routing is
# new.

# Staff inbox that receives every new ticket and reply. MUST be set in
# production; left empty by default so a fresh dev environment does not
# churn SMTP retries against a non-existent mailbox. At startup the
# gateway logs support_service_initialized with email_enabled=false
# when this value is empty, making the misconfiguration discoverable.
SUPPORT_INBOX_EMAIL=

# Optional category-specific overrides. When unset, the relevant
# tickets fall back to SUPPORT_INBOX_EMAIL.
SUPPORT_BILLING_INBOX_EMAIL=
SUPPORT_SECURITY_INBOX_EMAIL=

# Discord incoming webhook (Server Settings → Integrations → Webhooks).
# Empty to disable the Discord fan-out.
SUPPORT_DISCORD_WEBHOOK_URL=

# Telegram bot credentials. SUPPORT_TELEGRAM_CHAT_ID is the numeric ID
# of the group / channel / user the bot posts to. Use @userinfobot or
# the getUpdates API to discover it. Empty to disable.
SUPPORT_TELEGRAM_BOT_TOKEN=
SUPPORT_TELEGRAM_CHAT_ID=

# WhatsApp Cloud API (Meta Business). All three required to enable.
#   SUPPORT_WHATSAPP_TOKEN            -- system-user permanent access
#                                        token from Meta Business Suite.
#   SUPPORT_WHATSAPP_PHONE_NUMBER_ID  -- ID of the business number,
#                                        NOT the actual phone number.
#   SUPPORT_WHATSAPP_RECIPIENT        -- E.164 destination number with
#                                        country code, no '+' (e.g.
#                                        15555550100). The recipient
#                                        must have opted in or be
#                                        within the 24-hour customer-
#                                        service window.
SUPPORT_WHATSAPP_TOKEN=
SUPPORT_WHATSAPP_PHONE_NUMBER_ID=
SUPPORT_WHATSAPP_RECIPIENT=

# Public community URLs exposed via GET /api/support/community-links.
# These are the public group / channel / page links users click from
# the dashboard and landing page; they are deliberately distinct from
# the staff-only support channels above.
SUPPORT_COMMUNITY_FACEBOOK_URL=
SUPPORT_COMMUNITY_DISCORD_URL=
SUPPORT_COMMUNITY_TELEGRAM_URL=
SUPPORT_COMMUNITY_WHATSAPP_URL=

# Public site URL used in outbound emails (the 'Open in dashboard'
# button). Trailing slash is stripped automatically.
SUPPORT_PUBLIC_SITE_URL=https://exoper.com

# ══════════════════════════════════════════════════════════════════════════════
# Billing Microservice (Subscription & Payment Gateway)
# ══════════════════════════════════════════════════════════════════════════════
#
# The billing service is a standalone microservice that:
#   - Hosts the public webhook endpoints for Paddle and Lemon Squeezy.
#   - Verifies webhook signatures (HMAC-SHA256, replay-window protected).
#   - Persists processed event IDs for cross-retry idempotency.
#   - Updates billing_subscriptions in the shared PostgreSQL instance.
#   - Emits an immutable audit record for every transition.
#   - Revokes user sessions on tier change so JWTs cannot stay stale.
#
# Reads from the same DATABASE_URL as gateway/auth — no separate DB.
#
# Public endpoints (mounted OUTSIDE auth middleware; providers cannot send JWTs):
#   POST /webhooks/paddle
#   POST /webhooks/lemonsqueezy
#   GET  /health
#   GET  /readiness
#   GET  /metrics
#
# Internal endpoints (consumed by the gateway billing handler over
# service-to-service auth) — checkout creation lives here so provider
# API keys never leak to user-facing services:
#   POST /internal/checkout   (X-Internal-Auth required)

# ── Service binding ──────────────────────────────────────────────────────────
BILLING_HTTP_PORT=8082
BILLING_LOG_LEVEL=INFO
BILLING_LOG_JSON=true

# Public origin where Paddle/Lemon Squeezy will POST webhooks. Must be
# HTTPS in production. Used to construct success/cancel return URLs and
# logged on startup so operators can verify the value matches the URL
# registered in the provider dashboards.
BILLING_PUBLIC_BASE_URL=https://billing.exoper.com

# Replay window in seconds. Webhooks whose signed timestamp is older than
# now-N seconds are rejected. Stripe/Paddle both recommend 300s.
BILLING_WEBHOOK_REPLAY_WINDOW_SECONDS=300

# Maximum size of a webhook body the service will read. Anything larger is
# rejected before signature verification. 1 MiB is far above any real
# provider payload (~10 KiB typical).
BILLING_WEBHOOK_MAX_BODY_BYTES=1048576

# Period-end reconciler interval (seconds). Every tick the reconciler:
#   - demotes subscriptions in paused/past_due/canceled/refunded status
#     whose current_period_end has elapsed (and revokes their sessions),
#   - prunes processed_webhook_events older than the retention window.
# 900s (15 min) mirrors typical webhook retry windows so a missed
# cancellation event is reaped within one cycle of the provider's last
# retry attempt. Validated as positive at startup; a misconfigured value
# fails fast rather than silently disabling the reaper.
BILLING_RECONCILER_INTERVAL_SECONDS=900

# Idempotency-table retention (days). Rows in processed_webhook_events
# older than this are deleted by the reconciler's janitor pass. Idempotency
# only matters during the provider's retry window (Paddle and Lemon
# Squeezy both retry well under 7 days); 30 days is generous and bounds
# the table forever. Validated as positive at startup.
BILLING_IDEMPOTENCY_RETENTION_DAYS=30

# Frontend URLs the provider redirects the customer to after checkout.
BILLING_CHECKOUT_SUCCESS_URL=https://app.exoper.com/billing/success
BILLING_CHECKOUT_CANCEL_URL=https://app.exoper.com/billing/cancel

# Service-to-service auth: shared secret the gateway sends in the
# X-Internal-Auth header when calling /internal/checkout. Min 32 chars.
# Generate with: openssl rand -hex 32
BILLING_INTERNAL_SHARED_SECRET=CHANGE_ME_IN_PRODUCTION_MIN_32_CHARS

# URL the gateway uses to reach the billing service for /internal/checkout.
BILLING_SERVICE_URL=http://billing:8082

# Redis URL used by the billing service to PUBLISH SUBSCRIPTION_*
# realtime events on the shared etradie:alerts channel. The gateway
# subscribes to the same channel and fans out the event to every
# connected dashboard WebSocket so the SPA refetches
# /api/v1/billing/subscription and /auth/me the instant a webhook
# lands instead of waiting for React Query's staleTime to expire.
# Falls back to the top-level REDIS_URL when empty.
BILLING_REDIS_URL=

# ── Paddle ───────────────────────────────────────────────────────────────────
# Provider-dashboard values. All MUST be set in production; the service
# fails-fast on startup otherwise.
#
# Webhook secret: copy from Paddle dashboard → Notifications.
# API key: Paddle dashboard → Developer Tools → Authentication.
# Price IDs: Paddle dashboard → Catalog → Products → your Pro product
#            → "Prices" section. One price ID per tier.
PADDLE_WEBHOOK_SECRET=
PADDLE_API_KEY=
PADDLE_API_BASE_URL=https://api.paddle.com
PADDLE_PRICE_PRO_BYOK=
PADDLE_PRICE_PRO_MANAGED=

# ── Lemon Squeezy ────────────────────────────────────────────────────────────
# Webhook secret: Lemon Squeezy dashboard → Settings → Webhooks → "Signing secret".
# API key: Lemon Squeezy dashboard → Settings → API.
# Store ID: Lemon Squeezy dashboard → Stores.
# Variant IDs: dashboard → Products → your Pro product → variant page URL.
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_API_BASE_URL=https://api.lemonsqueezy.com
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_PRO_BYOK=
LEMONSQUEEZY_VARIANT_PRO_MANAGED=
