# ═══════════════════════════════════════════════════════════════
# eTradie Engine — Environment Variables
# Copy to .env and fill in all required values before startup.
#
# BROKER CONNECTIONS:
#   MT5 broker credentials (MetaAPI token, ZeroMQ host/port) are
#   now OPTIONAL in this file. Users can configure broker connections
#   via the dashboard UI instead (POST /api/broker/connections).
#   Dashboard connections are stored encrypted in PostgreSQL and
#   take precedence over env vars on startup.
#
#   Fallback chain: DB connection -> env vars -> no broker (user
#   must configure via dashboard).
#
#   If you set MT5 credentials here, they serve as the initial
#   fallback until the user configures a connection via dashboard.
#
# LLM CONNECTIONS:
#   Same pattern as broker. Users can configure LLM providers via
#   the dashboard (POST /api/llm/connections). Env vars are fallback.
# ═══════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────
APP_NAME=etradie-engine
APP_ENV=development
APP_DEBUG=false
APP_LOG_LEVEL=INFO

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=etradie
POSTGRES_USER=etradie
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=CHANGE_ME_IN_PRODUCTION
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# ── API Keys — Data Providers ────────────────────────────────
CFTC_API_BASE_URL=https://publicreporting.cftc.gov/resource
# CFTC Socrata app token (free, strongly recommended for reliable COT data).
# Without this, requests are throttled to ~1/min and may return 403.
# Register at: https://publicreporting.cftc.gov/profile/edit/developer_settings
CFTC_APP_TOKEN=

FRED_API_KEY=YOUR_FRED_KEY
FRED_BASE_URL=https://api.stlouisfed.org/fred

TWELVEDATA_API_KEY=YOUR_TWELVEDATA_KEY
TWELVEDATA_BASE_URL=https://api.twelvedata.com

# OECD Data Explorer (free, no key required)
OECD_API_BASE_URL=https://sdmx.oecd.org/public/rest/data

# Investing.com Economic Calendar RSS (free, no key required)
INVESTING_CALENDAR_RSS_URL=https://www.investing.com/rss/news_285.rss

# Commodity Proxy URLs (free, no API key required)
IRON_ORE_PRICE_URL=https://markets.businessinsider.com/commodities/iron-ore-price
DAIRY_GDT_PRICE_URL=https://www.globaldairytrade.info/en/gdt-events/summary-results/

# ── RSS Feed URLs — Central Banks ────────────────────────────
FED_RSS_URL=https://www.federalreserve.gov/feeds/press_all.xml
ECB_RSS_URL=https://www.ecb.europa.eu/rss/press.html
BOE_RSS_URL=https://www.bankofengland.co.uk/rss/news
BOJ_RSS_URL=https://www.boj.or.jp/en/rss/whatsnew.xml
RBA_RSS_URL=https://www.rba.gov.au/rss/rss-cb-media-releases.xml
BOC_RSS_URL=https://www.bankofcanada.ca/content_type/press-releases/feed/
RBNZ_RSS_URL=https://www.rbnz.govt.nz/rss/news
SNB_RSS_URL=https://www.snb.ch/en/mmr/reference/rss_en/source/rss_en.rss

# ── RSS Feed URLs — News ─────────────────────────────────────
REUTERS_RSS_URL=https://www.reutersagency.com/feed
BLOOMBERG_RSS_URL=https://feeds.bloomberg.com/markets/news.rss

# ── Polling Intervals (seconds) ─────────────────────────────
POLL_INTERVAL_CENTRAL_BANK_RSS=600
POLL_INTERVAL_NEWS=900
POLL_INTERVAL_CALENDAR=1800
POLL_INTERVAL_COT=604800
POLL_INTERVAL_DXY=14400
POLL_INTERVAL_INTERMARKET=86400
POLL_INTERVAL_SENTIMENT=604800
POLL_INTERVAL_ECONOMIC_DATA=3600

ANALYSIS_CYCLE_INTERVAL=14400

# ── HTTP Client Defaults ────────────────────────────────────
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3
HTTP_RETRY_BACKOFF_BASE=1.0
HTTP_RETRY_BACKOFF_MAX=60.0

# ── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST_SIZE=10

# ── Observability ───────────────────────────────────────────
# Leave OTEL_EXPORTER_OTLP_ENDPOINT empty to disable trace export
# cleanly. Set to a real collector URL (e.g. http://otel-collector:4317)
# to enable distributed tracing. An unreachable endpoint pollutes
# the log with dial-failure retries, so the default is now empty.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=etradie-engine
PROMETHEUS_METRICS_PORT=9090

# ── Cache TTL (seconds) ─────────────────────────────────────
CACHE_TTL_CENTRAL_BANK=600
CACHE_TTL_NEWS=300
CACHE_TTL_CALENDAR=900
CACHE_TTL_COT=86400
CACHE_TTL_DXY=14400
CACHE_TTL_INTERMARKET=43200
CACHE_TTL_SENTIMENT=86400
CACHE_TTL_ECONOMIC_DATA=1800

# ═══════════════════════════════════════════════════════════════
# Technical Analysis (TA) Module
# ═══════════════════════════════════════════════════════════════

TA_ENABLED=true
TA_SMC_ENABLED=true
TA_SND_ENABLED=true
TA_PRIMARY_BROKER=mt5
TA_FALLBACK_BROKER=twelve_data
TA_ANALYSIS_INTERVAL_SECONDS=60
TA_BACKFILL_ON_STARTUP=true
TA_MAX_CONCURRENT_SYMBOL_ANALYSIS=4

# -- MT5 Broker Connection (OPTIONAL - can be configured via dashboard) ----
#
# RECOMMENDED: Configure broker connections via the dashboard UI instead
# of setting these env vars. The dashboard provides:
#   - Encrypted credential storage in PostgreSQL
#   - Multiple saved connections (VPS EA, Local PC, MetaAPI)
#   - Activate/deactivate/test connections
#   - Hot-swap between connections without restart
#
# If you set these env vars, they serve as the FALLBACK broker when no
# active connection exists in the database. The app starts normally
# even if these are empty/missing.
#
# Provider: "metaapi" (cloud, any OS) or "native" (ZeroMQ bridge to Windows MT5)
MT5_ENABLED=true
MT5_PROVIDER=metaapi

# -- MetaApi Cloud ---------------------------------------------------------
# MT5_METAAPI_TOKEN is the PLATFORM-LEVEL developer token used by the
# server-side MetaApiProvisioner to provision per-user MT5 cloud
# accounts when users add MetaAPI broker connections via the dashboard
# (POST /api/broker/connections with connection_type="metaapi").
# Per-user account_ids are generated by the provisioner at connect
# time and persisted in broker_connections.metaapi_account_id.
MT5_METAAPI_TOKEN=

# -- ZeroMQ Native (optional - set via dashboard or here) ------------------
# Leave as defaults if configuring via dashboard POST /api/broker/connections
# with connection_type="ea".
# When using dashboard: user enters VPS IP or local PC IP in the EA setup form.
MT5_ZMQ_HOST=host.docker.internal
MT5_ZMQ_PORT=5555

# -- Shared operational settings -------------------------------------------
MT5_TIMEOUT_SECONDS=60
MT5_ENABLE_TICK_DATA=false

TRADINGVIEW_ENABLED=false
TRADINGVIEW_WEBHOOK_SECRET=YOUR_RANDOM_SECRET_STRING
TRADINGVIEW_WEBHOOK_PATH=/webhooks/tradingview
TRADINGVIEW_VALIDATE_SIGNATURE=true

# ═══════════════════════════════════════════════════════════════
# RAG Intelligence Engine (Module A — Sub-Module A3)
# ═══════════════════════════════════════════════════════════════

RAG_ENABLED=true

# ── RAG Embeddings ──────────────────────────────────────────
# Choose ONE provider and its matching model/dimensions.

# Option A: Local (SentenceTransformers) - Default for Dev
RAG_EMBEDDING_PROVIDER=sentence_transformers
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_EMBEDDING_DIMENSIONS=384

# Option B: Cloud (OpenAI) - Performance Mode
# RAG_EMBEDDING_PROVIDER=openai
# RAG_EMBEDDING_MODEL=text-embedding-3-large
# RAG_EMBEDDING_DIMENSIONS=3072
# RAG_OPENAI_API_KEY=YOUR_OPENAI_API_KEY

RAG_EMBEDDING_BATCH_SIZE=64
RAG_EMBEDDING_MAX_RETRIES=3
RAG_EMBEDDING_TIMEOUT_SECONDS=30
RAG_OPENAI_EMBEDDING_BASE_URL=https://api.openai.com/v1

RAG_VECTORSTORE_PROVIDER=chroma
RAG_CHROMA_HOST=chromadb
RAG_CHROMA_PORT=8000
RAG_CHROMA_AUTH_TOKEN=etradie_chroma_dev_token
RAG_CHROMA_SSL=false
RAG_COLLECTION_DOCUMENTS=etradie_documents
RAG_COLLECTION_SCENARIOS=etradie_scenarios

RAG_CHUNK_SIZE=1024
RAG_CHUNK_OVERLAP=128
RAG_CHUNK_MIN_SIZE=64
RAG_CHUNK_MAX_SIZE=2048

RAG_RETRIEVAL_TOP_K=150
RAG_RETRIEVAL_SCORE_THRESHOLD=0.20
RAG_RETRIEVAL_DEFAULT_STRATEGY=hybrid

RAG_RERANK_ENABLED=true
RAG_RERANK_TOP_K=130
RAG_RERANK_MODEL=rule_weighted

RAG_COVERAGE_MIN_RULE_CHUNKS=4
RAG_COVERAGE_MIN_FRAMEWORK_CHUNKS=3
RAG_CONFLICT_AUTO_REJECT=true

RAG_KNOWLEDGE_BASE_DIR=knowledge
RAG_SCENARIO_ASSETS_DIR=knowledge/scenarios

RAG_INGEST_ON_STARTUP=true
RAG_INGEST_MAX_CONCURRENT=4
RAG_INGEST_RETRY_MAX=3

RAG_CACHE_TTL_RETRIEVAL=300
RAG_CACHE_TTL_EMBEDDING=86400

# ═══════════════════════════════════════════════════════════════
# Processor Module (LLM Provider Configuration)
# ═══════════════════════════════════════════════════════════════

PROCESSOR_LLM_PROVIDER=anthropic
PROCESSOR_MODEL_NAME=
PROCESSOR_TEMPERATURE=0.0
PROCESSOR_MAX_OUTPUT_TOKENS=16384

PROCESSOR_ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

PROCESSOR_OPENAI_API_KEY=YOUR_OPENAI_API_KEY

PROCESSOR_GEMINI_API_KEY=YOUR_GEMINI_API_KEY

PROCESSOR_SELF_HOSTED_API_KEY=YOUR_SELF_HOSTED_KEY
PROCESSOR_API_BASE_URL=http://localhost:8000/v1

PROCESSOR_LLM_TIMEOUT_SECONDS=60
PROCESSOR_TOTAL_TIMEOUT_SECONDS=90
PROCESSOR_MAX_RETRIES=2
PROCESSOR_RETRY_BACKOFF_BASE_SECONDS=1.0
PROCESSOR_RETRY_BACKOFF_MAX_SECONDS=30.0

PROCESSOR_STRICT_SCHEMA_VALIDATION=true
PROCESSOR_REQUIRE_CITATIONS=true
PROCESSOR_PERSIST_AUDIT_LOGS=true
PROCESSOR_LOG_RAW_LLM_RESPONSE=false

