# ═══════════════════════════════════════════════════════════════
# eTradie Engine — Environment Variables
# Copy to .env and fill in all required values before startup.
# The application validates ALL required vars at boot and
# fails fast if any are missing or malformed.
# ═══════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────
APP_NAME=etradie-engine
APP_ENV=development
APP_DEBUG=false
APP_LOG_LEVEL=INFO

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=etradie
POSTGRES_USER=etradie
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# ── API Keys — Data Providers ────────────────────────────────
# CFTC COT data (CFTC.gov official API — no key required)
CFTC_API_BASE_URL=https://publicreporting.cftc.gov/resource

# TradingEconomics.com (https://tradingeconomics.com/api)
# Institutional-grade primary source for: economic calendar, economic
# releases, market data (backup), and sentiment indicators.
TRADINGECONOMICS_API_KEY=YOUR_TRADINGECONOMICS_KEY
TRADINGECONOMICS_BASE_URL=https://api.tradingeconomics.com

# FRED — Federal Reserve Economic Data (https://fred.stlouisfed.org/docs/api/)
# Free, official US economic data — backup for US releases only.
FRED_API_KEY=YOUR_FRED_KEY
FRED_BASE_URL=https://api.stlouisfed.org/fred

# NewsAPI (https://newsapi.org)
NEWSAPI_API_KEY=YOUR_NEWSAPI_KEY
NEWSAPI_BASE_URL=https://newsapi.org/v2

# Twelve Data (https://twelvedata.com)
# Primary source for DXY + intermarket data.
TWELVEDATA_API_KEY=YOUR_TWELVEDATA_KEY
TWELVEDATA_BASE_URL=https://api.twelvedata.com

# ── RSS Feed URLs — Central Banks ────────────────────────────
FED_RSS_URL=https://www.federalreserve.gov/feeds/press_all.xml
ECB_RSS_URL=https://www.ecb.europa.eu/rss/press.html
BOE_RSS_URL=https://www.bankofengland.co.uk/rss/news
BOJ_RSS_URL=https://www.boj.or.jp/en/rss/whatsnew.xml

# ── RSS Feed URLs — News ─────────────────────────────────────
REUTERS_RSS_URL=https://www.reutersagency.com/feed
BLOOMBERG_RSS_URL=https://feeds.bloomberg.com/markets/news.rss

# ── Polling Intervals (seconds) ─────────────────────────────
# Per-source schedules — each source runs on its natural cadence
POLL_INTERVAL_CENTRAL_BANK_RSS=600
POLL_INTERVAL_NEWS=900
POLL_INTERVAL_CALENDAR=1800
POLL_INTERVAL_COT=604800
POLL_INTERVAL_DXY=14400
POLL_INTERVAL_INTERMARKET=86400
POLL_INTERVAL_SENTIMENT=604800
POLL_INTERVAL_ECONOMIC_DATA=3600

# Analysis cycle interval (default: every 4 hours = 14400s)
ANALYSIS_CYCLE_INTERVAL=14400

# ── HTTP Client Defaults ────────────────────────────────────
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3
HTTP_RETRY_BACKOFF_BASE=1.0
HTTP_RETRY_BACKOFF_MAX=60.0

# ── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST_SIZE=10

# ── Observability ───────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=etradie-engine
PROMETHEUS_METRICS_PORT=9090

# ── Cache TTL (seconds) ─────────────────────────────────────
CACHE_TTL_CENTRAL_BANK=600
CACHE_TTL_NEWS=300
CACHE_TTL_CALENDAR=900
CACHE_TTL_COT=86400
CACHE_TTL_DXY=14400
CACHE_TTL_INTERMARKET=43200
CACHE_TTL_SENTIMENT=86400
CACHE_TTL_ECONOMIC_DATA=1800

# ═══════════════════════════════════════════════════════════════
# Technical Analysis (TA) Module
# ═══════════════════════════════════════════════════════════════

# ── General TA Settings ─────────────────────────────────────────
TA_ENABLED=true
TA_SMC_ENABLED=true
TA_SND_ENABLED=true
TA_PRIMARY_BROKER=mt5
TA_FALLBACK_BROKER=twelve_data
TA_ANALYSIS_INTERVAL_SECONDS=60
TA_BACKFILL_ON_STARTUP=true
TA_MAX_CONCURRENT_SYMBOL_ANALYSIS=4

# ── MetaTrader 5 (MT5) Settings ─────────────────────────────────
MT5_ENABLED=true
# Optional: Path to terminal64.exe (leave empty for auto-detect)
MT5_TERMINAL_PATH=
MT5_SERVER=YOUR_BROKER_SERVER_NAME
MT5_ACCOUNT=12345678
MT5_PASSWORD=YOUR_MT5_PASSWORD
MT5_TIMEOUT_SECONDS=60
MT5_ENABLE_TICK_DATA=false

# ── TradingView Webhook Settings (Optional) ─────────────────────
TRADINGVIEW_ENABLED=false
TRADINGVIEW_WEBHOOK_SECRET=YOUR_RANDOM_SECRET_STRING
TRADINGVIEW_WEBHOOK_PATH=/webhooks/tradingview
TRADINGVIEW_VALIDATE_SIGNATURE=true

# ═══════════════════════════════════════════════════════════════
# RAG Intelligence Engine (Module A — Sub-Module A3)
# ═══════════════════════════════════════════════════════════════

# ── General RAG Settings ───────────────────────────────────────
RAG_ENABLED=true

# ── Embedding Provider ────────────────────────────────────────
# Options: openai, nomic, sentence_transformers
RAG_EMBEDDING_PROVIDER=openai
RAG_EMBEDDING_MODEL=text-embedding-3-large
RAG_EMBEDDING_DIMENSIONS=3072
RAG_EMBEDDING_BATCH_SIZE=64
RAG_EMBEDDING_MAX_RETRIES=3
RAG_EMBEDDING_TIMEOUT_SECONDS=30

# ── Embedding API Keys ────────────────────────────────────────
RAG_OPENAI_API_KEY=YOUR_OPENAI_API_KEY
RAG_OPENAI_EMBEDDING_BASE_URL=https://api.openai.com/v1

# ── ChromaDB Vector Store ──────────────────────────────────────
RAG_VECTORSTORE_PROVIDER=chroma
RAG_CHROMA_HOST=chromadb
RAG_CHROMA_PORT=8000
RAG_CHROMA_AUTH_TOKEN=
RAG_CHROMA_SSL=false
RAG_COLLECTION_DOCUMENTS=etradie_documents
RAG_COLLECTION_SCENARIOS=etradie_scenarios

# ── Chunking Strategy ─────────────────────────────────────────
RAG_CHUNK_SIZE=1024
RAG_CHUNK_OVERLAP=128
RAG_CHUNK_MIN_SIZE=64
RAG_CHUNK_MAX_SIZE=2048

# ── Retrieval Settings ────────────────────────────────────────
RAG_RETRIEVAL_TOP_K=15
RAG_RETRIEVAL_SCORE_THRESHOLD=0.25
# Options: rule_first, scenario_first, macro_bias, hybrid
RAG_RETRIEVAL_DEFAULT_STRATEGY=hybrid

# ── Reranking ──────────────────────────────────────────────────
RAG_RERANK_ENABLED=true
RAG_RERANK_TOP_K=8
RAG_RERANK_MODEL=rule_weighted

# ── Coverage & Conflict Detection ──────────────────────────────
RAG_COVERAGE_MIN_RULE_CHUNKS=2
RAG_COVERAGE_MIN_FRAMEWORK_CHUNKS=1
RAG_CONFLICT_AUTO_REJECT=true

# ── Knowledge Base Paths ───────────────────────────────────────
RAG_KNOWLEDGE_BASE_DIR=docs
RAG_SCENARIO_ASSETS_DIR=docs/scenarios

# ── Ingest Pipeline ────────────────────────────────────────────
RAG_INGEST_ON_STARTUP=true
RAG_INGEST_MAX_CONCURRENT=4
RAG_INGEST_RETRY_MAX=3

# ── RAG Cache TTL (seconds) ─────────────────────────────────────
RAG_CACHE_TTL_RETRIEVAL=300
RAG_CACHE_TTL_EMBEDDING=86400

# ═══════════════════════════════════════════════════════════════
# Processor Module (LLM Provider Configuration)
# ═══════════════════════════════════════════════════════════════

# ── Processor General Settings ─────────────────────────────────
PROCESSOR_LLM_PROVIDER=anthropic
PROCESSOR_MODEL_NAME=
PROCESSOR_TEMPERATURE=0.0
PROCESSOR_MAX_OUTPUT_TOKENS=16384

# ── Processor API Keys (only the active provider's key is required) ─
# Anthropic (Claude models)
PROCESSOR_ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# OpenAI (GPT models)
PROCESSOR_OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Google Gemini
PROCESSOR_GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Self-hosted (OpenAI-compatible API)
PROCESSOR_SELF_HOSTED_API_KEY=YOUR_SELF_HOSTED_KEY
PROCESSOR_API_BASE_URL=http://localhost:8000/v1

# ── Processor Timeouts & Retries ───────────────────────────────
PROCESSOR_LLM_TIMEOUT_SECONDS=60
PROCESSOR_TOTAL_TIMEOUT_SECONDS=90
PROCESSOR_MAX_RETRIES=2
PROCESSOR_RETRY_BACKOFF_BASE_SECONDS=1.0
PROCESSOR_RETRY_BACKOFF_MAX_SECONDS=30.0

# ── Processor Validation & Audit ───────────────────────────────
PROCESSOR_STRICT_SCHEMA_VALIDATION=true
PROCESSOR_REQUIRE_CITATIONS=true
PROCESSOR_PERSIST_AUDIT_LOGS=true
PROCESSOR_LOG_RAW_LLM_RESPONSE=false

# ═══════════════════════════════════════════════════════════════
# Execution Engine (Module B) Configuration
# ═══════════════════════════════════════════════════════════════

# ── Execution Server Settings ──────────────────────────────────
EXECUTION_GRPC_PORT=50053
EXECUTION_HTTP_PORT=8080

# ── Execution Broker Configuration ─────────────────────────────
EXECUTION_BROKER_MODE=mock
# MT5 Broker Bridge URL (points to Python engine service)
EXECUTION_BROKER_BRIDGE_URL=http://localhost:8000
EXECUTION_BROKER_TIMEOUT_MS=5000

# ── Mock Broker Settings ───────────────────────────────────────
EXECUTION_MOCK_BROKER_BALANCE=10000.0

# ── Module C Address (for instant mode arming) ─────────────────
EXECUTION_MODULE_C_ADDR=localhost:50055

# ── Execution Mode & Position Sizing ───────────────────────────
EXECUTION_DEFAULT_EXECUTION_MODE=LIMIT
EXECUTION_MIN_LOT_SIZE=0.01
EXECUTION_MAX_LOT_SIZE=10.0

# ── Risk Controls ──────────────────────────────────────────────
EXECUTION_MAX_CONCURRENT_TRADES=3
EXECUTION_DAILY_LOSS_LIMIT_PCT=3.0
EXECUTION_WEEKLY_DRAWDOWN_PCT=5.0

# ── Spread Thresholds ──────────────────────────────────────────
EXECUTION_SPREAD_MULTIPLIER_NORMAL=2.0
EXECUTION_SPREAD_MULTIPLIER_SCALPING=1.5

# ── News Lockout (minutes) ────────────────────────────────────
EXECUTION_NEWS_LOCKOUT_MINUTES=30
EXECUTION_NEWS_LOCKOUT_MINUTES_SCALPING=45

# ── Enabled Trading Sessions ───────────────────────────────────
EXECUTION_ENABLED_SESSIONS=LONDON_OPEN,LONDON_NY_OVERLAP,NEW_YORK

# ── Instant Mode Configuration ─────────────────────────────────
EXECUTION_OVERSHOOT_TOLERANCE_MULTIPLIER=1.5

# ── Execution Database (separate from engine if needed) ────────
# If not set, uses same DATABASE_URL as engine
EXECUTION_DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
EXECUTION_DATABASE_MAX_CONNS=10
EXECUTION_DATABASE_MIN_CONNS=2
EXECUTION_DATABASE_MAX_IDLE_MS=30000
EXECUTION_DATABASE_CONN_MAX_LIFE_SECONDS=3600

# ── Execution Redis ────────────────────────────────────────────
EXECUTION_REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/1

# ── Execution Observability ───────────────────────────────────
EXECUTION_LOG_LEVEL=INFO
EXECUTION_LOG_JSON=true
EXECUTION_OTEL_ENDPOINT=localhost:4317
EXECUTION_OTEL_SERVICE_NAME=etradie-execution

# ═══════════════════════════════════════════════════════════════
# Gateway Service (Module C) Configuration
# ═══════════════════════════════════════════════════════════════

# ── Gateway Server Settings ────────────────────────────────────
GATEWAY_HTTP_PORT=8080
GATEWAY_GRPC_PORT=50052

# ── Gateway Symbols Control ────────────────────────────────────
GATEWAY_ENABLED=true
GATEWAY_DEFAULT_SYMBOLS=EURUSD,GBPUSD,USDJPY,USDCHF,AUDUSD,NZDUSD,USDCAD,XAUUSD

# ── Gateway Cycle Timing ──────────────────────────────────────
GATEWAY_CYCLE_INTERVAL_SECONDS=14400
GATEWAY_CYCLE_TIMEOUT_SECONDS=300

# ── Gateway Parallelism Settings ──────────────────────────────
GATEWAY_MAX_CONCURRENT_SYMBOLS=4
GATEWAY_TA_MACRO_PARALLEL_TIMEOUT_SECONDS=120

# ── Gateway Sub-Module Timeouts ────────────────────────────────
GATEWAY_RAG_TIMEOUT_SECONDS=30
GATEWAY_PROCESSOR_TIMEOUT_SECONDS=60
GATEWAY_GUARD_TIMEOUT_SECONDS=10

# ── Gateway Result Caching TTLs ────────────────────────────────
GATEWAY_TA_CACHE_TTL_SECONDS=300
GATEWAY_MACRO_CACHE_TTL_SECONDS=600

# ── Gateway Retry Policy ──────────────────────────────────────
GATEWAY_MAX_CYCLE_RETRIES=1
GATEWAY_RETRY_BACKOFF_BASE_SECONDS=2.0

# ── Gateway Logging ────────────────────────────────────────────
GATEWAY_LOG_FULL_CONTEXT_PAYLOAD=false
GATEWAY_LOG_LEVEL=INFO
GATEWAY_LOG_JSON=true

# ── Gateway Engine Service URL (Python engine internal API) ────
GATEWAY_ENGINE_HTTP_URL=http://localhost:8000

# ── Gateway Redis ──────────────────────────────────────────────
GATEWAY_REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0
GATEWAY_REDIS_MAX_CONNECTIONS=20

# ── Gateway Observability ──────────────────────────────────────
GATEWAY_OTEL_ENDPOINT=localhost:4317
GATEWAY_OTEL_SERVICE_NAME=etradie-gateway

# ── Gateway Execution Engine Connection (Module B) ─────────────
GATEWAY_EXECUTION_ENABLED=true
GATEWAY_EXECUTION_ADDR=localhost:50053
GATEWAY_EXECUTION_TIMEOUT_MS=5000

# ═══════════════════════════════════════════════════════════════
# SMC (Smart Money Concepts) Technical Analysis Settings
# ═══════════════════════════════════════════════════════════════

SMC_ENABLED=true
SMC_MIN_DISPLACEMENT_PIPS=20.0
SMC_MIN_SWEEP_PIPS=5.0
SMC_TURTLE_SOUP_MIN_PIPS=5.0
SMC_TURTLE_SOUP_MIN_SL_PIPS=10.0
SMC_OB_BODY_PERCENTAGE_THRESHOLD=50.0
SMC_FVG_MIN_GAP_PIPS=2.0
SMC_REQUIRE_FVG_WITH_OB=true
SMC_REQUIRE_PREMIUM_DISCOUNT=true
SMC_REQUIRE_SESSION_TIMING=true
SMC_REQUIRE_HTF_BMS_ALIGNMENT=true
SMC_MIN_CONFLUENCES=3
SMC_ENABLE_TURTLE_SOUP=true
SMC_ENABLE_SH_BMS_RTO=true
SMC_ENABLE_SMS_BMS_RTO=true
SMC_ENABLE_AMD=true
SMC_ENABLE_COMBINED_PATTERNS=true

# ═══════════════════════════════════════════════════════════════
# SND (Supply & Demand) Technical Analysis Settings
# ═══════════════════════════════════════════════════════════════

SND_ENABLED=true
SND_MARUBOZU_BODY_PERCENTAGE_THRESHOLD=80.0
SND_MARUBOZU_MAX_WICK_PERCENTAGE=10.0
SND_MIN_PREVIOUS_TOUCHES=2
SND_PREVIOUS_LEVEL_TOLERANCE_PIPS=3.0
SND_MIN_FAKEOUT_TESTS=1
SND_COMPRESSION_MIN_CANDLES=3
SND_COMPRESSION_MAX_RANGE_PIPS=15.0
SND_REQUIRE_PREMIUM_DISCOUNT=true
SND_REQUIRE_FIBONACCI_CONFLUENCE=false
SND_FIBONACCI_TOLERANCE_PIPS=5.0
SND_ENABLE_QML_BASELINE=true
SND_ENABLE_QML_MPL=true
SND_ENABLE_QML_PREVIOUS_LEVELS_TYPE1=true
SND_ENABLE_QML_PREVIOUS_LEVELS_TYPE2=true
SND_ENABLE_TRIPLE_FAKEOUT=true
SND_ENABLE_FAKEOUT_KING=true
SND_ENABLE_SOP=true

# ═══════════════════════════════════════════════════════════════
# Broker-Specific Configuration
# ═══════════════════════════════════════════════════════════════

# ── MetaTrader 5 (MT5) Advanced Settings ───────────────────────
MT5_TERMINAL_PATH=
MT5_CONNECTION_TIMEOUT_SECONDS=30
MT5_MAX_CANDLES_PER_REQUEST=5000
MT5_ENABLE_TICK_DATA=false

# ── TradingView Webhook Advanced Settings ──────────────────────
TRADINGVIEW_MAX_PAYLOAD_SIZE_BYTES=10240
TRADINGVIEW_SIGNATURE_HEADER=X-TradingView-Signature
TRADINGVIEW_TIMEOUT_SECONDS=10
TRADINGVIEW_ALLOWED_IPS=
TRADINGVIEW_VALIDATE_SIGNATURE=true

# ── Twelve Data Advanced Settings ──────────────────────────────
TWELVE_DATA_TIMEOUT_SECONDS=30
TWELVE_DATA_MAX_RETRIES=3
TWELVE_DATA_RETRY_DELAY_SECONDS=2
TWELVE_DATA_RATE_LIMIT_PER_MINUTE=8
TWELVE_DATA_MAX_CANDLES_PER_REQUEST=5000
TWELVE_DATA_CACHE_TTL_SECONDS=300

# ═══════════════════════════════════════════════════════════════
# Advanced HTTP & Circuit Breaker Settings
# ═══════════════════════════════════════════════════════════════

# ── Rate Limiting & Circuit Breaker Thresholds ─────────────────
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60
CIRCUIT_BREAKER_HALF_OPEN_MAX_CALLS=3
