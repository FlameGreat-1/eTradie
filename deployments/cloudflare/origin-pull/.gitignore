# Generated by generate-dev-certs.sh. Never commit.
#
# Note: origin-pull-ca.pem has TWO different lifecycles:
#   - In dev: produced by generate-dev-certs.sh, gitignored.
#   - In CI bootstrap: produced by
#     refresh-cloudflare-ips.sh --bootstrap, MUST be committed.
# To commit the production-baseline copy, use:
#     git add -f deployments/cloudflare/origin-pull/origin-pull-ca.pem
# This .gitignore prevents accidental dev-cert commits; -f overrides
# it for the deliberate bootstrap commit.
origin-pull-ca.pem
dev-aop-ca.pem
dev-aop-ca.key
dev-aop-ca.srl
dev-client.csr
dev-client.crt
dev-client.key
