# eTradie dashboard — frontend environment variables
#
# Copy this file to `.env.local` for local overrides. Only VITE_-prefixed
# variables are exposed to the browser bundle; anything else is ignored
# at build time.
#
# NEVER put secrets (Google client secret, JWT signing key, broker API
# keys, LLM API keys) in this file. Those live on the gateway and never
# reach the browser.

# ── Backend service URLs ────────────────────────────────────
VITE_ENGINE_URL=http://localhost:8000
VITE_GATEWAY_HTTP_URL=http://localhost:8080
VITE_GATEWAY_WS_URL=ws://localhost:8080
VITE_EXECUTION_URL=http://localhost:8081
VITE_MANAGEMENT_URL=http://localhost:8083

# ── Google OAuth 2.0 ────────────────────────────────────────
#
# Set VITE_GOOGLE_OAUTH_ENABLED=true to surface the "Continue with
# Google" button on the login and register pages. The gateway must
# also have AUTH_GOOGLE_OAUTH_ENABLED=true and the rest of its
# AUTH_GOOGLE_* configuration filled in for sign-in to actually work.
#
# VITE_OAUTH_CALLBACK_PATH must match the path component of the
# AUTH_GOOGLE_REDIRECT_URI registered in Google Cloud Console.
# Default: /auth/callback/google
VITE_GOOGLE_OAUTH_ENABLED=false
VITE_OAUTH_CALLBACK_PATH=/auth/callback/google
